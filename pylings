# ── Hints ────────────────────────────────────────────────────────────────────


def print_hints(n):
    path = mod_path(n)
    if not os.path.exists(path):
        return

    with open(path) as f:
        lines = f.readlines()

    todos = []
    for i, line in enumerate(lines):
        stripped = line.strip()
        if "# TODO:" in stripped:
            msg = stripped.split("# TODO:", 1)[1].strip()
            todos.append(msg)
        elif "raise NotImplementedError" in stripped:
            for j in range(i - 1, -1, -1):
                prev = lines[j].strip()
                if prev.startswith("def "):
                    name = prev.split("(")[0].replace("def ", "")
                    todos.append(f"Implement the function '{name}()'")
                    break

    if not todos:
        print(f"\n  {DIM}No TODO items found — check the file for instructions.{RESET}\n")
        return

    print(f"\n{BOLD}{CYAN}── Hints for Module {n} ──{RESET}\n")
    for todo in todos:
        print(f"  {YELLOW}◷{RESET}  {todo}")
    print()


# ── Watch mode ───────────────────────────────────────────────────────────────


def watch_mod(n):
    if n is None:
        print(f"\n{YELLOW}No incomplete exercises found.{RESET}")
        print(f"  Run {CYAN}pylings list{RESET} to see all exercises.\n")
        return

    if not is_not_done(n):
        print(f"\n{GREEN}Module {n} is already complete!{RESET}")
        print(f"  Run {CYAN}pylings list{RESET} or try a different module.\n")
        return

    path = mod_path(n)
    last_mtime = 0

    print(f"\n{YELLOW}Watching Module {n} — {MODULE_TITLES[n]}{RESET}")
    print(f"{DIM}Tests re-run on save. Press 'q' to quit, 'h' for hints.{RESET}\n")

    fd = sys.stdin.fileno()
    use_keys = os.isatty(fd)
    old = None
    if use_keys:
        try:
            old = termios.tcgetattr(fd)
            tty.setcbreak(fd)
        except Exception:
            old = None

    try:
        while True:
            if not os.path.exists(path):
                print(f"\n{RED}File not found: {path}{RESET}")
                break

            mtime = os.path.getmtime(path)

            if mtime != last_mtime:
                last_mtime = mtime
                os.system('clear' if os.name == 'posix' else 'cls')

                all_passed = run_mod(n)

                if not is_not_done(n):
                    print(f"{GREEN}{BOLD}Module {n} complete!{RESET}")
                    next_n = find_next()
                    if next_n:
                        print(f"Moving to Module {next_n}...")
                        n = next_n
                        path = mod_path(n)
                        last_mtime = os.path.getmtime(path)
                    else:
                        print(f"\n{GREEN}{BOLD}All exercises complete!{RESET}\n")
                        break

            if old is not None:
                rlist, _, _ = select.select([sys.stdin], [], [], 1)
                if rlist:
                    ch = sys.stdin.read(1)
                    if not ch:
                        break
                    if ch.lower() == 'q':
                        print(f"\n{YELLOW}Goodbye!{RESET}\n")
                        break
                    elif ch.lower() == 'h':
                        print_hints(n)
            else:
                try:
                    time.sleep(1)
                except KeyboardInterrupt:
                    print(f"\n{YELLOW}Goodbye!{RESET}\n")
                    break
    finally:
        if old is not None:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)


# ── CLI ──────────────────────────────────────────────────────────────────────


def print_usage():
    print(f"\n{BOLD}Usage:{RESET}")
    print(f"  {CYAN}pylings list{RESET}          List all exercises with status")
    print(f"  {CYAN}pylings next{RESET}          Run the next incomplete exercise")
    print(f"  {CYAN}pylings <N>{RESET}            Run exercise N (e.g. {CYAN}pylings 3{RESET})")
    print(f"  {CYAN}pylings watch{RESET}          Watch the next incomplete exercise")
    print(f"  {CYAN}pylings watch <N>{RESET}      Watch exercise N")
    print(f"\n{DIM}In watch mode: press 'q' to quit, 'h' for hints.{RESET}\n")


def main():
    if len(sys.argv) < 2:
        n = find_next()
        if n is None:
            print(f"\n{GREEN}{BOLD}All exercises complete! Great work!{RESET}\n")
            return
        print(f"\n{GREEN}Starting watch mode for Module {n} — {MODULE_TITLES[n]}{RESET}\n")
        watch_mod(n)
        return

    if sys.argv[1] in ("list", "ls", "status"):
        list_exercises()
        return

    cmd = sys.argv[1]

    if cmd in ("help", "--help", "-h"):
        print_usage()
        return

    if cmd == "next":
        n = find_next()
        if n is None:
            print(f"\n{GREEN}{BOLD}All exercises complete! Great work!{RESET}\n")
            return
        all_passed = run_mod(n)
        return

    if cmd == "watch":
        n = int(sys.argv[2]) if len(sys.argv) > 2 else find_next()
        watch_mod(n)
        return

    try:
        n = int(cmd)
        if n not in TEST_MAP:
            print(f"\n{RED}Invalid module number.{RESET} Choose from: {', '.join(str(k) for k in TEST_MAP)}\n")
            sys.exit(1)
        all_passed = run_mod(n)
    except ValueError:
        print(f"\n{RED}Unknown command: {cmd}{RESET}")
        print_usage()
        sys.exit(1)


if __name__ == "__main__":
    main()
