GREEN = "\033[92m"
RED = "\033[91m"
YELLOW = "\033[93m"
CYAN = "\033[96m"
BOLD = "\033[1m"
DIM = "\033[2m"
RESET = "\033[0m"


MODULE_TITLES = {
    1: "Variables, Math, and Functions",
    2: "Data Types and Functions",
